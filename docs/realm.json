{
  "realm": "appointment-booking-DEV",
  "enabled": true,
  "registrationAllowed": true,
  "registrationEmailAsUsername": false,
  "editUsernameAllowed": true,
  "rememberMe": true,
  "verifyEmail": true,
  "loginWithEmailAllowed": true,
  "resetPasswordAllowed": true,
  "duplicateEmailsAllowed": false,

  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 600,
  "ssoSessionMaxLifespan": 600,
  "offlineSessionIdleTimeout": 2592000,
  "offlineSessionMaxLifespan": 5184000,
  "accessCodeLifespan": 60,
  "accessCodeLifespanLogin": 1800,
  "accessCodeLifespanUserAction": 300,
  "actionTokenGeneratedByAdminLifespan": 43200,
  "actionTokenGeneratedByUserLifespan": 300,
  "refreshTokenMaxReuse": 0,

  "bruteForceProtected": true,
  "permanentLockout": false,
  "failureFactor": 5,
  "waitIncrementSeconds": 60,
  "maxFailureWaitSeconds": 900,
  "maxDeltaTimeSeconds": 43200,
  "minimumQuickLoginWaitSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,

  "passwordPolicy": "length(6) and upperCase(1) and lowerCase(1) and specialChars(1) and digits(1) and notUsername() and passwordHistory(3)",

  "eventsEnabled": true,
  "adminEventsEnabled": true,
  "adminEventsDetailsEnabled": true,
  "eventsExpiration": 604800,
  "enabledEventTypes": [
    "REGISTER",
    "LOGIN",
    "LOGIN_ERROR",
    "LOGOUT",
    "UPDATE_PROFILE",
    "DELETE_ACCOUNT",
    "TOKEN_EXCHANGE",
    "CLIENT_LOGIN",
    "CLIENT_LOGIN_ERROR",
    "CODE_TO_TOKEN",
    "CODE_TO_TOKEN_ERROR",
    "REFRESH_TOKEN",
    "REFRESH_TOKEN_ERROR"
  ],
  "eventsListeners": [
    "jboss-logging"
  ],


  "requiredActions": [
    {
      "alias": "VERIFY_EMAIL",
      "name": "Verify Email",
      "providerId": "VERIFY_EMAIL",
      "enabled": true,
      "defaultAction": true,
      "priority": 50,
      "config": {}
    },
    {
      "alias": "UPDATE_PASSWORD",
      "name": "Update Password",
      "providerId": "UPDATE_PASSWORD",
      "enabled": true,
      "defaultAction": false,
      "priority": 30,
      "config": {}
    },
    {
      "alias": "CONFIGURE_TOTP",
      "name": "Configure OTP",
      "providerId": "CONFIGURE_TOTP",
      "enabled": true,
      "defaultAction": false,
      "priority": 10,
      "config": {}
    },
    {
      "alias": "UPDATE_PROFILE",
      "name": "Update Profile",
      "providerId": "UPDATE_PROFILE",
      "enabled": true,
      "defaultAction": false,
      "priority": 40,
      "config": {}
    },
    {
      "alias": "delete_account",
      "name": "Delete Account",
      "providerId": "delete_account",
      "enabled": true,
      "defaultAction": false,
      "priority": 60,
      "config": {}
    }
  ],

  "clients": [
    {
      "clientId": "appointment-booking",
      "name": "Appointment Booking Service",
      "description": "OpenID Connect client for the Appointment Booking System",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "${CLIENT_SECRET:change-me-in-production}",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "fullScopeAllowed": true,
      "attributes": {
        "use.refresh.tokens": "true",
        "client_credentials.use_refresh_token": "false",
        "token.response.type.bearer.lower-case": "true",
        "oauth2.token.exchange.grant.enabled": "true",
        "oidc.ciba.grant.enabled": "false",
        "backchannel.logout.session.required": "true",
        "backchannel.logout.revoke.offline.tokens": "false",
        "post.logout.redirect.uris": "+"
      },
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:8081/*",
        "https://appointment.client.local/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:8081",
        "https://appointment.client.local"
      ],
      "defaultClientScopes": [
        "openid",
        "email",
        "profile",
        "roles"
      ],
      "optionalClientScopes": [
        "offline_access",
        "microprofile-jwt"
      ],
      "protocolMappers": [
        {
          "name": "customer-role-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "introspection.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String",
            "usermodel.clientRoleMapping.clientId": "appointment-booking"
          }
        },
        {
          "name": "audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "appointment-booking",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    }
  ],

  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Realm admin role"
      },
      {
        "name": "manage-users",
        "description": "Manage users role"
      },
      {
        "name": "view-users",
        "description": "View users role"
      },
      {
        "name": "manage-clients",
        "description": "Manage clients role"
      },
      {
        "name": "view-clients",
        "description": "View clients role"
      },
      {
        "name": "manage-realm-user-profile",
        "description": "Manage realm user profile"
      }
    ],
    "client": {
      "appointment-booking": [
        {
          "name": "app_user",
          "description": "Basic user role for all authenticated customers"
        },
        {
          "name": "app_staff",
          "description": "Staff role for branch consultants",
          "composite": true,
          "composites": {
            "client": {
              "appointment-booking": [
                "app_user"
              ]
            }
          }
        },
        {
          "name": "app_admin",
          "description": "Admin role for branch managers",
          "composite": true,
          "composites": {
            "client": {
              "appointment-booking": [
                "app_user",
                "app_staff"
              ]
            }
          }
        }
      ]
    }
  },

  "defaultDefaultClientScopes": [
    "openid",
    "email",
    "profile",
    "roles"
  ],

  "defaultGroups": [
    "/USER"
  ],

  "groups": [
    {
      "name": "USER"
    },
    {
      "name": "STAFF"
    },
    {
      "name": "ADMIN"
    }
  ],

  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "email": "admin@your-domain.com",
      "firstName": "System",
      "lastName": "Administrator",
      "credentials": [
        {
          "type": "password",
          "value": "@89GYew67YN",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin",
        "manage-users",
        "view-users",
        "manage-clients",
        "view-clients",
        "manage-realm-user-profile"
      ],
      "clientRoles": {
        "realm-management": [
          "manage-clients",
          "view-clients",
          "query-clients",
          "manage-users",
          "manage-realm-user-profile",
          "view-users",
          "manage-realm",
          "view-realm",
          "query-groups",
          "query-users",
          "manage-groups",
          "realm-admin",
          "query-realms",
          "token-exchange",
          "impersonation"
        ],
        "appointment-booking": [
          "app_user",
          "app_staff",
          "app_admin"
        ]
      },
      "groups": [
        "/ADMIN"
      ]
    },
    {
      "username": "service-account-appointment-booking",
      "enabled": true,
      "serviceAccountClientId": "appointment-booking",
      "clientRoles": {
        "realm-management": [
          "manage-clients",
          "view-clients",
          "query-clients",
          "manage-users",
          "manage-realm-user-profile",
          "view-users",
          "manage-realm",
          "view-realm",
          "query-groups",
          "query-users",
          "manage-groups",
          "realm-admin",
          "query-realms",
          "token-exchange",
          "impersonation"
        ]
      }
    }
  ]
}

